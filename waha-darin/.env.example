APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack

# Default local stack is often MySQL. For Neon / Render, switch to pgsql and set DATABASE_URL (see docs/DEPLOY_PREVIEW.md).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# --- PostgreSQL (Neon / Render) example ---
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=laravel
# DB_USERNAME=forge
# DB_PASSWORD=
# DB_SSLMODE=require
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Single URL for MySQL (e.g. Railway):
# DATABASE_URL=mysql://user:pass@host:port/dbname

# Read-only MySQL source for: php artisan data:import-catalog-from-mysql (default DB must be pgsql).
# MYSQL_SOURCE_DATABASE=your_old_mysql_db
# MYSQL_SOURCE_USERNAME=root
# MYSQL_SOURCE_PASSWORD=
# MYSQL_SOURCE_HOST=127.0.0.1
# MYSQL_SOURCE_PORT=3306
# MYSQL_SOURCE_DATABASE_URL=mysql://...

# Must match the public HTTPS URL of the web service (same as APP_URL for Docker + Nuxt on one host).
# Railway: https://your-app.up.railway.app
# Render:  https://your-service.onrender.com
# CLIENT_URL="${APP_URL}"

# Optional: set to your public origin if mixed-content warnings appear (often same as APP_URL on Render).
# ASSET_URL="${APP_URL}"

# Trust the platform proxy (Render/Railway). Production boot also forces https URLs in AppServiceProvider.
# FORCE_HTTPS_URLS=false

# Docker entrypoint: when APP_ENV=production, run `php artisan migrate --force` before Apache unless disabled.
# RUN_MIGRATIONS_ON_BOOT=true

# Required for API JWT auth (tymon/jwt-auth). Generate a long random string for production.
# JWT_SECRET=

# Preview only: skip verification email and mark new users verified (requires no SMTP). Do not use on public production.
# SKIP_EMAIL_VERIFICATION=false

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

# Laravel 7 also reads MAIL_DRIVER if present (keep in sync with MAIL_MAILER).
# MAIL_DRIVER=smtp

# --- Brevo: send via HTTPS API (no SMTP). Set on Render for transactional mail. ---
# MAIL_MAILER=brevo
# MAIL_DRIVER=brevo
# BREVO_API_KEY=xkeysib-your-brevo-rest-api-key-here
# MAIL_FROM_ADDRESS must be a verified sender in Brevo.
# BREVO_API_KEY is the only secret required for this driver; MAIL_HOST/USERNAME/PASSWORD are ignored.

# --- SendGrid (production / Render): set in the dashboard, never commit the API key ---
# MAIL_MAILER=smtp
# MAIL_DRIVER=smtp
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your_sendgrid_api_key_here
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=info@your-domain.com
# MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
